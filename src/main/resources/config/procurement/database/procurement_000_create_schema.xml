<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Phase 2.5.5: every procurement table lives in the dedicated
        `procurement` schema. Must run before any other procurement
        changelog because all subsequent <createTable> tags carry
        schemaName="procurement" and Liquibase does not auto-create the
        schema.
    -->
    <changeSet id="phase2.5.5-create-schema-procurement" author="phase2.5.5">
        <sql>CREATE SCHEMA IF NOT EXISTS procurement</sql>
    </changeSet>

</databaseChangeLog>
