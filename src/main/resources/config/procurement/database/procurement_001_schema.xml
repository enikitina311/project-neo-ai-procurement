            baseColumnNames="package_id"
            constraintName="fk_procurement_kp_documents_package_id"
            referencedTableSchemaName="procurement" referencedTableName="packages"
            referencedColumnNames="id"
            onDelete="CASCADE" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="kp_documents"
            baseColumnNames="supplier_id"
            constraintName="fk_procurement_kp_documents_supplier_id"
            referencedTableSchemaName="procurement" referencedTableName="suppliers"
            referencedColumnNames="id"
            onDelete="CASCADE" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="kp_documents"
            baseColumnNames="created_by"
            constraintName="fk_procurement_kp_documents_created_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="kp_documents"
            baseColumnNames="updated_by"
            constraintName="fk_procurement_kp_documents_updated_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />
    </changeSet>

    <!--
        kp_documents was originally created with a hard FK to suppliers (via
        supplier_id). The "with-detected-supplier" rework drops that FK and
        replaces supplier_id with a free-text supplier_name pulled out of the
        document during extraction. Must run AFTER the create above; on a
        fresh install the relocate of this changeset (Phase 2.5.7) restored
        that ordering — previously it sat near the top of the file and broke
        fresh-DB boots.
    -->
    <changeSet id="procurement-kp-documents-with-detected-supplier" author="codex">
        <dropForeignKeyConstraint baseTableSchemaName="procurement" baseTableName="kp_documents"
            constraintName="fk_procurement_kp_documents_supplier_id" />

        <dropIndex indexName="idx_procurement_kp_documents_supplier_id"
            schemaName="procurement" tableName="kp_documents" />

        <dropColumn schemaName="procurement" tableName="kp_documents" columnName="supplier_id" />

        <addColumn schemaName="procurement" tableName="kp_documents">
            <column name="file_name" type="text" />
            <column name="supplier_name" type="text" />
        </addColumn>
    </changeSet>

