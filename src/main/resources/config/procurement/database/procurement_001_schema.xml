<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!-- ========================================================= -->
    <!-- PROCUREMENT PACKAGES -->
    <!-- ========================================================= -->
    <changeSet id="procurement-packages" author="system">
        <validCheckSum>ANY</validCheckSum>
        <createTable schemaName="procurement" tableName="packages">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="project_id" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="name" type="varchar(255)">
                <constraints nullable="false" />
            </column>

            <column name="criteria_text" type="text" />
            <column name="coverage_threshold" type="numeric(6,4)" defaultValueNumeric="0.7" />
            <column name="suppliers_limit" type="int" defaultValueNumeric="10" />

            <column name="created_by" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="updated_by" type="uuid">
                <constraints nullable="true" />
            </column>

            <column name="created_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
            <column name="updated_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
        </createTable>

        <createIndex indexName="idx_procurement_packages_project_id"
            schemaName="procurement" tableName="packages">
            <column name="project_id" />
        </createIndex>

        <createIndex indexName="idx_procurement_packages_created_by"
            schemaName="procurement" tableName="packages">
            <column name="created_by" />
        </createIndex>

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="packages"
            baseColumnNames="project_id"
            constraintName="fk_procurement_packages_project_id"
            referencedTableSchemaName="core" referencedTableName="projects"
            referencedColumnNames="id"
            onDelete="CASCADE" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="packages"
            baseColumnNames="created_by"
            constraintName="fk_procurement_packages_created_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="packages"
            baseColumnNames="updated_by"
            constraintName="fk_procurement_packages_updated_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />
    </changeSet>

    <changeSet id="procurement-packages-coverage-threshold" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="procurement" tableName="packages" columnName="coverage_threshold" />
            </not>
        </preConditions>
        <addColumn schemaName="procurement" tableName="packages">
            <column name="coverage_threshold" type="numeric(6,4)" defaultValueNumeric="0.7" />
        </addColumn>
    </changeSet>

    <changeSet id="procurement-packages-suppliers-limit" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="procurement" tableName="packages" columnName="suppliers_limit" />
            </not>
        </preConditions>
        <addColumn schemaName="procurement" tableName="packages">
            <column name="suppliers_limit" type="int" defaultValueNumeric="10" />
        </addColumn>
    </changeSet>

    <!-- ========================================================= -->
    <!-- PROCUREMENT ITEMS -->
    <!-- ========================================================= -->
    <changeSet id="procurement-items" author="system">
        <validCheckSum>ANY</validCheckSum>
        <createTable schemaName="procurement" tableName="items">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="package_id" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="name" type="text">
                <constraints nullable="false" />
            </column>

            <column name="specs" type="text" />
            <column name="qty" type="numeric(14,4)" />
            <column name="unit" type="varchar(50)" />

            <column name="created_by" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="updated_by" type="uuid">
                <constraints nullable="true" />
            </column>

            <column name="created_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
            <column name="updated_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
        </createTable>

        <createIndex indexName="idx_procurement_items_package_id"
            schemaName="procurement" tableName="items">
            <column name="package_id" />
        </createIndex>

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="items"
            baseColumnNames="package_id"
            constraintName="fk_procurement_items_package_id"
            referencedTableSchemaName="procurement" referencedTableName="packages"
            referencedColumnNames="id"
            onDelete="CASCADE" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="items"
            baseColumnNames="created_by"
            constraintName="fk_procurement_items_created_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="items"
            baseColumnNames="updated_by"
            constraintName="fk_procurement_items_updated_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />
    </changeSet>

