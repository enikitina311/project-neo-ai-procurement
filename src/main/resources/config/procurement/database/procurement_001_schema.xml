        </preConditions>

        <createTable schemaName="procurement" tableName="supplier_search_runs">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="package_id" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="query" type="text" />
            <column name="status" type="varchar(32)">
                <constraints nullable="false" />
            </column>
            <column name="request_payload_json" type="jsonb" />
            <column name="result_raw" type="text" />
            <column name="result_parsed_json" type="jsonb" />
            <column name="error_text" type="text" />
            <column name="n8n_execution_id" type="varchar(255)" />
            <column name="cancel_requested" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false" />
            </column>
            <column name="started_at" type="timestamp with time zone" />
            <column name="finished_at" type="timestamp with time zone" />

            <column name="created_by" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="updated_by" type="uuid">
                <constraints nullable="true" />
            </column>

            <column name="created_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
            <column name="updated_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
        </createTable>

        <createIndex indexName="idx_procurement_supplier_search_runs_package_id"
            schemaName="procurement" tableName="supplier_search_runs">
            <column name="package_id" />
        </createIndex>

        <createIndex indexName="idx_procurement_supplier_search_runs_status"
