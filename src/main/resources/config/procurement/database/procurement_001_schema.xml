            baseTableSchemaName="procurement" baseTableName="supplier_search_runs"
            baseColumnNames="package_id"
            constraintName="fk_procurement_supplier_search_runs_package_id"
            referencedTableSchemaName="procurement" referencedTableName="packages"
            referencedColumnNames="id"
