        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="kp_analysis"
            baseColumnNames="kp_document_id"
            constraintName="fk_procurement_kp_analysis_document_id"
            referencedTableSchemaName="procurement" referencedTableName="kp_documents"
            referencedColumnNames="id"
            onDelete="CASCADE" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="kp_analysis"
            baseColumnNames="created_by"
            constraintName="fk_procurement_kp_analysis_created_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />

        <addForeignKeyConstraint
            baseTableSchemaName="procurement" baseTableName="kp_analysis"
            baseColumnNames="updated_by"
            constraintName="fk_procurement_kp_analysis_updated_by"
            referencedTableSchemaName="core" referencedTableName="users"
            referencedColumnNames="id"
            onDelete="RESTRICT" />
    </changeSet>

    <!--
        kp_analysis evolutions: a sequence of additive column additions that
        accumulated over time. Originally placed near the top of the file
        (Phase 0 of procurement) — this is the legacy chronological order, not
        the right ORDER for fresh-install runs. Phase 2.5.7 moves them after
        the create above so a clean DB boots end-to-end.
    -->
    <changeSet id="procurement-kp-analysis-supplier-name" author="codex">
        <addColumn schemaName="procurement" tableName="kp_analysis">
            <column name="supplier_name" type="text" />
        </addColumn>
    </changeSet>

    <changeSet id="procurement-kp-analysis-source-text" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="procurement" tableName="kp_analysis" columnName="source_text" />
            </not>
        </preConditions>
        <addColumn schemaName="procurement" tableName="kp_analysis">
            <column name="source_text" type="text" />
        </addColumn>
    </changeSet>

    <changeSet id="procurement-kp-analysis-summary" author="codex">
