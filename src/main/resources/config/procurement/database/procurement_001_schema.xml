    <!-- ========================================================= -->
    <!-- PROCUREMENT KP DOCUMENTS -->
    <!-- ========================================================= -->
    <changeSet id="procurement-kp-documents" author="system">
        <validCheckSum>ANY</validCheckSum>
        <createTable schemaName="procurement" tableName="kp_documents">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="package_id" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="supplier_id" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="file_id" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="uploaded_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />

            <column name="created_by" type="uuid">
                <constraints nullable="false" />
            </column>

            <column name="updated_by" type="uuid">
                <constraints nullable="true" />
            </column>

            <column name="created_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
            <column name="updated_at" type="timestamp with time zone"
                defaultValueComputed="NOW()" />
        </createTable>

        <createIndex indexName="idx_procurement_kp_documents_package_id"
            schemaName="procurement" tableName="kp_documents">
            <column name="package_id" />
        </createIndex>

        <createIndex indexName="idx_procurement_kp_documents_supplier_id"
