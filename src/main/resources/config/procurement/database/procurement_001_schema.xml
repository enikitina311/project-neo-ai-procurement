    <!-- ========================================================= -->
    <!-- PROCUREMENT SUPPLIER SEARCH RUNS -->
    <!-- ========================================================= -->
    <changeSet id="procurement-supplier-search-runs" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="procurement" tableName="supplier_search_runs" />
